{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ergo Bounty Submission",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "contributor",
    "wallet_address",
    "work_title",
    "payment_currency",
    "bounty_value",
    "status"
  ],
  "properties": {
    "contributor": {
      "type": "string",
      "minLength": 1,
      "not": { "enum": ["YOUR_GITHUB_USERNAME"] }
    },
    "wallet_address": {
      "type": "string",
      "minLength": 1,
      "not": { "enum": ["YOUR_WALLET_ADDRESS"] }
    },
    "contact_method": {
      "type": "string",
      "not": { "enum": ["YOUR_CONTACT_INFO"] }
    },
    "work_link": {
      "type": "string",
      "pattern": "^$|^https://github\\.com/[^/]+/[^/]+/pull/[0-9]+$"
    },
    "work_title": {
      "type": "string",
      "minLength": 1
    },
    "bounty_id": {
      "type": "string"
    },
    "original_issue_link": {
      "type": "string",
      "pattern": "^$|^https://github\\.com/[^/]+/[^/]+/(issues|pull)/[0-9]+$"
    },
    "payment_currency": {
      "type": "string",
      "minLength": 1
    },
    "bounty_value": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "status": {
      "type": "string",
      "enum": ["in-progress", "awaiting-review", "reviewed", "paid"]
    },
    "submission_date": {
      "type": "string",
      "pattern": "^$|^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "expected_completion": {
      "type": "string",
      "pattern": "^$|^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "reviewer": {
      "type": "string"
    },
    "review_notes": {
      "type": "string"
    },
    "payment_tx_id": {
      "type": "string"
    },
    "payment_date": {
      "type": "string",
      "pattern": "^$|^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "paid" } },
        "required": ["status"]
      },
      "then": {
        "required": ["payment_tx_id", "payment_date"],
        "properties": {
          "payment_tx_id": { "minLength": 1 },
          "payment_date": { "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "enum": ["awaiting-review", "reviewed", "paid"] } },
        "required": ["status"]
      },
      "then": {
        "required": ["work_link", "submission_date"],
        "properties": {
          "work_link": { "pattern": "^https://github\\.com/[^/]+/[^/]+/pull/[0-9]+$" },
          "submission_date": { "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }
        }
      }
    }
  ]
}
